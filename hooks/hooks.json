{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ruby ${CLAUDE_PLUGIN_ROOT}/bin/compress"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ruby ${CLAUDE_PLUGIN_ROOT}/bin/compress"
          }
        ]
      }
    ]
  }
}
